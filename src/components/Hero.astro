---
---
<section class="pt-32 pb-20 px-6 text-center">
  <div class="max-w-3xl mx-auto">

    <!-- Badge -->
    <div class="inline-flex items-center gap-2 text-xs font-medium text-accent bg-accent/10 border border-accent/20 px-3 py-1 rounded-full mb-6">
      <span class="w-1.5 h-1.5 rounded-full bg-accent animate-pulse"></span>
      Now available for macOS
    </div>

    <!-- Headline -->
    <h1 class="text-5xl md:text-6xl font-bold tracking-tight leading-[1.1] mb-5">
      From idea to<br />
      <span class="text-accent">real working app.</span>
    </h1>

    <!-- Subheadline -->
    <p class="text-lg text-gray-400 leading-relaxed max-w-2xl mx-auto mb-10">
      Write your ideas as user stories. Instify assigns them to the best AI agent,
      runs them automatically — even overnight — and delivers a working app.
      You stay in control without staying in the loop.
    </p>

    <!-- CTAs -->
    <div class="flex flex-col sm:flex-row items-center justify-center gap-3" id="download">
      <a
        href="#"
        class="flex items-center gap-2.5 bg-white text-black font-semibold px-6 py-3 rounded-xl hover:bg-gray-100 transition-colors text-sm"
      >
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
          <path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/>
        </svg>
        Download for Mac
      </a>
      <a
        href="https://github.com/teivz/open-works"
        target="_blank"
        rel="noopener"
        class="flex items-center gap-2.5 text-gray-300 font-medium px-6 py-3 rounded-xl border border-border hover:border-gray-600 hover:text-white transition-colors text-sm"
      >
        <svg width="15" height="15" viewBox="0 0 98 96" fill="currentColor">
          <path d="M48.854 0C21.839 0 0 22 0 49.217c0 21.756 13.993 40.172 33.405 46.69 2.427.49 3.316-1.059 3.316-2.362 0-1.141-.08-5.052-.08-9.127-13.59 2.934-16.42-5.867-16.42-5.867-2.184-5.704-5.42-7.17-5.42-7.17-4.448-3.015.324-3.015.324-3.015 4.934.326 7.523 5.052 7.523 5.052 4.367 7.496 11.404 5.378 14.235 4.074.404-3.178 1.699-5.378 3.074-6.6-10.839-1.141-22.243-5.378-22.243-24.283 0-5.378 1.94-9.778 5.014-13.2-.485-1.222-2.184-6.275.486-13.038 0 0 4.125-1.304 13.426 5.052a46.97 46.97 0 0 1 12.214-1.63c4.125 0 8.33.571 12.213 1.63 9.302-6.356 13.427-5.052 13.427-5.052 2.67 6.763.97 11.816.485 13.038 3.155 3.422 5.015 7.822 5.015 13.2 0 18.905-11.404 23.06-22.324 24.283 1.78 1.548 3.316 4.481 3.316 9.126 0 6.6-.08 11.897-.08 13.526 0 1.304.89 2.853 3.316 2.364 19.412-6.52 33.405-24.935 33.405-46.691C97.707 22 75.788 0 48.854 0z"/>
        </svg>
        View on GitHub
      </a>
    </div>

    <!-- App mockup -->
    <div class="mt-16 relative">
      <div class="absolute inset-0 bg-gradient-to-b from-transparent via-transparent to-[#080808] z-10 pointer-events-none" style="top: 55%"></div>
      <div class="rounded-2xl border border-border bg-card overflow-hidden shadow-2xl shadow-black/60">
        <!-- Titlebar -->
        <div class="flex items-center gap-1.5 px-4 py-3 border-b border-border bg-[#161616]">
          <div class="w-3 h-3 rounded-full bg-[#FF5F57]"></div>
          <div class="w-3 h-3 rounded-full bg-[#FEBC2E]"></div>
          <div class="w-3 h-3 rounded-full bg-[#28C840]"></div>
          <span class="ml-3 text-xs text-gray-500 font-medium">Instify — my-saas-app</span>
        </div>
        <div class="flex h-64">
          <!-- Sidebar -->
          <div class="w-44 border-r border-border p-3 flex flex-col gap-1 text-xs">
            <div class="text-gray-500 font-medium px-2 py-1">Projects</div>
            {['my-saas-app', 'mobile-app'].map((name, i) => (
              <div class={`flex items-center gap-2 px-2 py-1.5 rounded-md ${i === 0 ? 'bg-accent/15 text-accent' : 'text-gray-400'}`}>
                <div class={`w-1.5 h-1.5 rounded-full ${i === 0 ? 'bg-accent' : 'bg-gray-600'}`}></div>
                {name}
              </div>
            ))}
            <div class="mt-auto border-t border-border pt-2 text-gray-500 px-2 py-1">AI Agents</div>
            <div class="flex items-center gap-2 px-2 py-1.5 rounded-md text-gray-400">
              <div class="w-1.5 h-1.5 rounded-full bg-green-500"></div>
              Claude Code
            </div>
            <div class="flex items-center gap-2 px-2 py-1.5 rounded-md text-gray-400">
              <div class="w-1.5 h-1.5 rounded-full bg-purple-500"></div>
              Codex
            </div>
          </div>
          <!-- Board -->
          <div class="flex-1 p-4 flex flex-col gap-3 overflow-hidden">
            <div class="flex items-center justify-between mb-1">
              <span class="text-sm font-medium">my-saas-app</span>
              <span class="text-xs text-green-400 bg-green-400/10 px-2 py-0.5 rounded-full">3 running</span>
            </div>
            {[
              { text: 'User auth with GitHub OAuth', agent: 'Claude', status: 'green', label: 'Done' },
              { text: 'Monthly revenue dashboard', agent: 'Codex', status: 'blue', label: 'Running' },
              { text: 'Export data to CSV — scheduled', agent: '—', status: 'yellow', label: 'Queued' },
            ].map(({ text, agent, status, label }) => (
              <div class="flex items-center gap-3 p-2.5 rounded-lg bg-[#111] border border-border text-xs">
                <div class={`w-2 h-2 rounded-full flex-shrink-0 ${
                  status === 'green' ? 'bg-green-500' :
                  status === 'blue' ? 'bg-blue-400 animate-pulse' : 'bg-yellow-500'
                }`}></div>
                <span class="text-gray-300 flex-1 truncate">{text}</span>
                <span class="text-gray-500">{agent}</span>
                <span class={`px-1.5 py-0.5 rounded text-[10px] font-medium ${
                  status === 'green' ? 'bg-green-500/15 text-green-400' :
                  status === 'blue' ? 'bg-blue-500/15 text-blue-400' : 'bg-yellow-500/15 text-yellow-400'
                }`}>{label}</span>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>

  </div>
</section>
