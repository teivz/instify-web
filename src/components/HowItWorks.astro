---
const steps = [
  {
    number: '01',
    title: 'Capture your ideas as stories',
    description: 'Write what you want to build in plain language — user stories on a kanban board. Each story is a clear, actionable unit of work. No technical spec needed.',
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>`,
  },
  {
    number: '02',
    title: 'Best agent for each task',
    description: 'Instify assigns each story to the AI agent best suited for it — Claude Code for complex reasoning, Codex for fast iteration. Use them together to cover every angle.',
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8m-4-4v4"/><path d="m9 8 2 2-2 2m4 0h2"/></svg>`,
  },
  {
    number: '03',
    title: 'Runs automatically, even overnight',
    description: "Agents execute stories end-to-end without hand-holding. Hit a session quota? Instify queues remaining work and resumes automatically — your app keeps building while you sleep.",
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>`,
  },
]
---
<section id="how-it-works" class="py-24 px-6">
  <div class="max-w-5xl mx-auto">

    <div class="text-center mb-16">
      <p class="text-accent text-sm font-semibold uppercase tracking-widest mb-3">How it works</p>
      <h2 class="text-3xl md:text-4xl font-bold tracking-tight text-prose">Write it. Assign it. Ship it.</h2>
      <p class="text-dim mt-3 max-w-lg mx-auto text-base">No DevOps. No babysitting. Just stories turning into real, working software.</p>
    </div>

    <div class="grid md:grid-cols-3 gap-6">
      {steps.map((step) => (
        <div class="relative p-6 rounded-2xl border border-edge bg-panel hover:border-accent/40 transition-colors">
          <div class="flex items-center justify-between mb-5">
            <div class="w-10 h-10 rounded-xl bg-accent/10 text-accent flex items-center justify-center" set:html={step.icon} />
            <span class="text-4xl font-bold text-prose/5 select-none">{step.number}</span>
          </div>
          <h3 class="text-base font-semibold mb-2 text-prose">{step.title}</h3>
          <p class="text-sm text-dim leading-relaxed">{step.description}</p>
        </div>
      ))}
    </div>

  </div>
</section>
