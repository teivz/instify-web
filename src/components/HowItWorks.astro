---
const steps = [
  {
    number: '01',
    title: 'Write your stories',
    description:
      'Describe features as user stories on a simple kanban board. No code required — just write what you want to build in plain language.',
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>`,
  },
  {
    number: '02',
    title: 'Agents take over',
    description:
      'Instify dispatches Claude Code or OpenAI Codex to each story. Agents read your codebase, write the code, and iterate until it works.',
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8m-4-4v4"/><path d="m9 8 2 2-2 2m4 0h2"/></svg>`,
  },
  {
    number: '03',
    title: 'Review and ship',
    description:
      'Watch execution output in real time. When the agent finishes, review the diff and merge. Your app grows autonomously, story by story.',
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>`,
  },
]
---
<section id="how-it-works" class="py-24 px-6">
  <div class="max-w-5xl mx-auto">

    <div class="text-center mb-16">
      <p class="text-accent text-sm font-semibold uppercase tracking-widest mb-3">How it works</p>
      <h2 class="text-3xl md:text-4xl font-bold tracking-tight">Three steps to autonomous coding</h2>
    </div>

    <div class="grid md:grid-cols-3 gap-6">
      {steps.map((step) => (
        <div class="relative p-6 rounded-2xl border border-border bg-card group hover:border-accent/40 transition-colors">
          <div class="flex items-center justify-between mb-5">
            <div class="w-10 h-10 rounded-xl bg-accent/10 text-accent flex items-center justify-center" set:html={step.icon} />
            <span class="text-4xl font-bold text-white/5 select-none">{step.number}</span>
          </div>
          <h3 class="text-base font-semibold mb-2">{step.title}</h3>
          <p class="text-sm text-gray-400 leading-relaxed">{step.description}</p>
        </div>
      ))}
    </div>

  </div>
</section>
